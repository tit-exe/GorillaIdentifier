# Field data (large binaries, never tracked)
data/photos/*
!data/photos/.gitkeep
!data/photos/README.md
data/wild_images/raw/*
!data/wild_images/raw/.gitkeep
!data/wild_images/raw/README.md
data/crops/
data/crops.json
data/crops.bak

# Model weights (large binaries, download from Zenodo, see README)
models/*.pt
models/*.pth
models/*.onnx
models/*.tflite
models/.cache/
models/yolo_export_tmp/
models/*_saved_model/

# Training output (regenerated by the pipeline)
output/
runs/

# Python cache
__pycache__/
*.py[cod]

# HuggingFace / PyTorch cache, if redirected inside the repo
HuggingFaceCache/
TorchCache/
hf_cache/
torch_cache/

# Temporary files
*.tmp
*.bak
*.log

# Editors and OS
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
